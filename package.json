{
  "name": "lead-engine-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "npm run typecheck && npm run test && npm run test:e2e",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:bootstrap": "npm run prisma:generate && npm run prisma:migrate:deploy && npm run db:seed",
    "db:seed": "tsx scripts/seed-prisma.ts",
    "db:provision": "tsx scripts/provision-workspace.ts",
    "generate-secrets": "tsx scripts/generate-secrets.ts",
    "worker:provider": "tsx scripts/run-provider-worker.ts",
    "validate-adapter": "tsx scripts/validate-adapter.ts",
    "providers:status": "tsx scripts/providers-status.ts",
    "db:migrate:status": "prisma migrate status",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:push": "prisma db push",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@fontsource/manrope": "^5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "@prisma/client": "^6.19.3",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "prisma": "^6.19.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
