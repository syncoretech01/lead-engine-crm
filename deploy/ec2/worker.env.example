# Copy this file to /etc/syncore/worker.env on the EC2 worker.
# Do not commit real production secrets.

DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require"
SYNCORE_STORAGE_DRIVER="prisma"
SYNCORE_ALLOW_FILE_STORAGE_IN_PRODUCTION="false"
SYNCORE_SEED_SNAPSHOT="false"

SYNCORE_AUTH_SECRET="replace-with-the-same-production-auth-secret-used-by-vercel"
SYNCORE_WEBHOOK_SECRET="replace-with-provider-shared-secret"
SYNCORE_CREDENTIAL_ENCRYPTION_KEY="replace-with-the-same-production-credential-encryption-key-used-by-vercel"
SYNCORE_CREDENTIAL_KEY_ID="production-key"
SYNCORE_APP_URL="https://leadenginecrm-five.vercel.app"
SYNCORE_ENABLE_LIVE_PROVIDERS="true"
SYNCORE_WORKER_LOOP_MS="60000"

SYNCORE_MAILING_ADDRESS="Syncore Tech, 1500 N Grant St, Denver, CO 80203, USA"
SYNCORE_OUTREACH_FROM="Bobby Jones <bobby@syncoretech.com>"
SYNCORE_OUTREACH_REPLY_TO="replies@syncoretech.com"
SYNCORE_UNSUBSCRIBE_SECRET="replace-with-the-same-production-unsubscribe-secret-used-by-vercel"
SYNCORE_OUTREACH_BATCH_SIZE="50"

APOLLO_API_KEY="replace-with-apollo-api-key"
GOOGLE_PLACES_API_KEY="replace-with-google-places-api-key"
APIFY_TOKEN="replace-with-apify-token"
HUNTER_API_KEY="replace-with-hunter-api-key"
ZEROBOUNCE_API_KEY="replace-with-zerobounce-api-key"
TWILIO_ACCOUNT_SID="replace-with-twilio-account-sid"
TWILIO_AUTH_TOKEN="replace-with-twilio-auth-token"
RINGCENTRAL_CLIENT_ID="replace-with-ringcentral-client-id"
RINGCENTRAL_CLIENT_SECRET="replace-with-ringcentral-client-secret"
RINGCENTRAL_JWT="replace-with-ringcentral-jwt"
RINGCENTRAL_SERVER_URL="https://platform.ringcentral.com"
SMARTLEAD_API_KEY="replace-with-smartlead-api-key"
AWS_SES_REGION="us-east-1"
AWS_ACCESS_KEY_ID="replace-with-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="replace-with-aws-secret-access-key"
