generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppStateSnapshot {
  id        String   @id
  version   Int
  state     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum WorkspaceRole {
  ADMIN
  MANAGER
  SDR
  DATA_OPERATOR
  VIEWER
  COMPLIANCE_ADMIN
}

enum JobStatus {
  DRAFT
  QUEUED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum ProcessingStatus {
  PENDING
  NORMALIZED
  FAILED
  SUPPRESSED
}

enum VerificationGrade {
  A
  B
  C
  D
  S
}

enum PriorityTier {
  P1
  P2
  P3
  P4
  S
}

enum OpportunityStage {
  PROSPECTING
  QUALIFIED
  DISCOVERY
  PROPOSAL
  CLOSED_WON
  CLOSED_LOST
}

enum ActivityType {
  EMAIL
  CALL
  SMS
  NOTE
  TASK
  MEETING
  STATUS_CHANGE
  VERIFICATION
  OPPORTUNITY
}

enum SuppressionType {
  UNSUBSCRIBE
  HARD_BOUNCE
  DO_NOT_CALL
  EXISTING_CUSTOMER
  COMPETITOR
  SPAM_COMPLAINT
  SMS_OPT_OUT
  INTERNAL
  DISQUALIFIED
  DELETION_REQUEST
}

model Workspace {
  id                  String               @id @default(cuid())
  name                String
  market              String?
  seats               Int                  @default(0)
  health              String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  members             WorkspaceMember[]
  integrations        Integration[]
  searchProfiles      SearchProfile[]
  leadJobs            LeadJob[]
  rawLeads            RawLead[]
  normalizedRecords   NormalizedRecord[]
  companies           Company[]
  contacts            Contact[]
  fieldSources        FieldSource[]
  verificationResults VerificationResult[]
  enrichmentResults   EnrichmentResult[]
  segments            Segment[]
  recordSegments      RecordSegment[]
  leadScores          LeadScore[]
  exports             Export[]
  accounts            Account[]
  opportunities       Opportunity[]
  activities          Activity[]
  tasks               Task[]
  notes               Note[]
  callLogs            CallLog[]
  customFields        CustomField[]
  customFieldValues   CustomFieldValue[]
  sdrTeams            SdrTeam[]
  sdrAssignments      SdrAssignment[]
  followUpReminders   FollowUpReminder[]
  reassignmentRules   ReassignmentRule[]
  outreachProviders   OutreachProvider[]
  outreachCampaigns   OutreachCampaign[]
  campaignSequences   CampaignSequence[]
  sequenceSteps       SequenceStep[]
  emailEvents         EmailEvent[]
  smsEvents           SmsEvent[]
  trackedCalls        TrackedCall[]
  reportSnapshots     ReportSnapshot[]
  retentionPolicies   RetentionPolicy[]
  retentionRuns       RetentionRun[]
  complianceChecklistItems ComplianceChecklistItem[]
  dataSubjectRequests DataSubjectRequest[]
  deliverabilityAlerts DeliverabilityAlert[]
  aiPersonalizations   AiPersonalization[]
  aiReplyClassifications AiReplyClassification[]
  aiCallSummaries      AiCallSummary[]
  aiLeadScorePredictions AiLeadScorePrediction[]
  aiIcpRecommendations AiIcpRecommendation[]
  aiDeliverabilityRecommendations AiDeliverabilityRecommendation[]
  aiRevenueInsights    AiRevenueInsight[]
  aiAutomationRuns     AiAutomationRun[]
  suppressionRecords  SuppressionRecord[]
  auditLogs           AuditLog[]
}

model User {
  id          String            @id @default(cuid())
  email       String            @unique
  name        String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  memberships WorkspaceMember[]
  createdJobs LeadJob[]         @relation("LeadJobCreator")
  ownedOpportunities Opportunity[] @relation("OpportunityOwner")
  ownedTasks  Task[]            @relation("TaskOwner")
  createdTasks Task[]           @relation("TaskCreator")
  createdNotes Note[]           @relation("NoteCreator")
  callLogs    CallLog[]
  managedSdrTeams SdrTeam[]     @relation("SdrTeamManager")
  assignedSdrAssignments SdrAssignment[] @relation("AssignedSdr")
  createdSdrAssignments SdrAssignment[]  @relation("AssignmentCreator")
  ownedFollowUpReminders FollowUpReminder[] @relation("ReminderOwner")
  ownedOutreachCampaigns OutreachCampaign[] @relation("CampaignOwner")
  createdCampaignSequences CampaignSequence[] @relation("SequenceCreator")
  smsEvents SmsEvent[]
  trackedCalls TrackedCall[]
  activities  Activity[]
  generatedReportSnapshots ReportSnapshot[] @relation("ReportSnapshotGenerator")
  retentionRuns RetentionRun[] @relation("RetentionRunActor")
  resolvedDeliverabilityAlerts DeliverabilityAlert[] @relation("DeliverabilityAlertResolver")
  handledDataSubjectRequests DataSubjectRequest[] @relation("DataSubjectRequestHandler")
  generatedAiPersonalizations AiPersonalization[] @relation("AiPersonalizationGenerator")
  createdAiIcpRecommendations AiIcpRecommendation[] @relation("AiIcpRecommendationCreator")
  aiAutomationRuns AiAutomationRun[] @relation("AiAutomationRunActor")
  auditLogs   AuditLog[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole
  createdAt   DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId, role])
}

model Integration {
  id          String    @id @default(cuid())
  workspaceId String
  provider    String
  status      String
  trustScore  Int       @default(50)
  config      Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider])
}

model SearchProfile {
  id                String    @id @default(cuid())
  workspaceId       String
  profileName       String
  targetMarket      String?
  targetIndustries  String[]
  targetGeographies String[]
  targetTitles      String[]
  requiredFields    String[]
  excludedKeywords  String[]
  excludedDomains   String[]
  sourcePreferences Json
  scoringProfile    String?
  segmentRules      Json
  defaultRouting    Json?
  complianceNotes   String?
  createdById       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leadJobs          LeadJob[]

  @@index([workspaceId, profileName])
}

model LeadJob {
  id                     String          @id @default(cuid())
  workspaceId            String
  searchProfileId        String?
  jobName                String
  selectedSources        String[]
  sourceConfigs          Json
  status                 JobStatus       @default(DRAFT)
  priority               String          @default("normal")
  estimatedRecords       Int             @default(0)
  rawRecordsCount        Int             @default(0)
  normalizedRecordsCount Int             @default(0)
  duplicateRecordsCount  Int             @default(0)
  suppressedRecordsCount Int             @default(0)
  verifiedEmailCount     Int             @default(0)
  verifiedPhoneCount     Int             @default(0)
  enrichedRecordsCount   Int             @default(0)
  exportedRecordsCount   Int             @default(0)
  pushedToCrmCount       Int             @default(0)
  failedRecordsCount     Int             @default(0)
  estimatedCostCents     Int             @default(0)
  actualCostCents        Int             @default(0)
  complianceNotes        String?
  errorSummary           String?
  createdById            String?
  startedAt              DateTime?
  completedAt            DateTime?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  workspace              Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  searchProfile          SearchProfile?  @relation(fields: [searchProfileId], references: [id])
  createdBy              User?           @relation("LeadJobCreator", fields: [createdById], references: [id])
  sourceRuns             LeadJobSource[]
  rawLeads               RawLead[]
  exports                Export[]

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
}

model LeadJobSource {
  id               String    @id @default(cuid())
  leadJobId        String
  source           String
  config           Json
  status           JobStatus @default(QUEUED)
  providerCursor   String?
  requestMetadata  Json?
  responseMetadata Json?
  creditUsage      Int       @default(0)
  checkpoint       Json?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  leadJob          LeadJob   @relation(fields: [leadJobId], references: [id], onDelete: Cascade)

  @@unique([leadJobId, source])
}

model RawLead {
  id               String            @id @default(cuid())
  workspaceId      String
  leadJobId        String
  source           String
  sourceRecordId   String
  sourcePayload    Json
  sourceUrl        String?
  sourceConfidence Int?
  extractedAt      DateTime          @default(now())
  processingStatus ProcessingStatus  @default(PENDING)
  processingError  String?
  normalizedRecord NormalizedRecord?
  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leadJob          LeadJob           @relation(fields: [leadJobId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, source, sourceRecordId])
  @@index([workspaceId, leadJobId])
}

model NormalizedRecord {
  id             String    @id @default(cuid())
  workspaceId    String
  rawLeadId      String    @unique
  leadJobId      String?
  companyName    String?
  normalizedName String?
  domain         String?
  website        String?
  contactName    String?
  title          String?
  seniority      String?
  email          String?
  phone          String?
  city           String?
  state          String?
  country        String?
  linkedinUrl    String?
  industry       String?
  technology     String[]
  grade          String?
  score          Int       @default(0)
  priority       String?
  status         String?
  segment        String?
  owner          String?
  verification   String?
  suppressionReason String?
  normalizedAt   DateTime  @default(now())
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  rawLead        RawLead   @relation(fields: [rawLeadId], references: [id], onDelete: Cascade)

  @@index([workspaceId, domain])
  @@index([workspaceId, email])
  @@index([workspaceId, leadJobId])
}

model Company {
  id             String        @id @default(cuid())
  workspaceId    String
  name           String
  normalizedName String
  rootDomain     String?
  website        String?
  linkedinUrl    String?
  googlePlaceId  String?
  phone          String?
  industry       String?
  employeeBand   String?
  revenueBand    String?
  city           String?
  state          String?
  country        String?
  sourceLineage  Json
  confidence     Int           @default(50)
  score          Int           @default(0)
  priority       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts       Contact[]
  fieldSources   FieldSource[]
  account        Account?

  @@index([workspaceId, rootDomain])
  @@index([workspaceId, normalizedName])
}

model Contact {
  id            String               @id @default(cuid())
  workspaceId   String
  companyId     String?
  fullName      String
  title         String?
  seniority     String?
  department    String?
  email         String?
  phone         String?
  linkedinUrl   String?
  sourceLineage Json
  confidence    Int                  @default(50)
  grade         String?
  score         Int                   @default(0)
  priority      String?
  status        String?
  segment       String?
  owner         String?
  verification  String?
  enrichmentCoverage Int?
  fitReason     String?
  enrichedAt    DateTime?
  lawfulBasis   String?
  consentStatus String?
  consentSource String?
  consentCapturedAt DateTime?
  doNotContact  Boolean              @default(false)
  isSuppressed  Boolean              @default(false)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  workspace     Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company       Company?             @relation(fields: [companyId], references: [id])
  fieldSources  FieldSource[]
  verifications VerificationResult[]
  enrichments   EnrichmentResult[]
  scores        LeadScore[]
  crmContacts   CrmContact[]
  dataSubjectRequests DataSubjectRequest[]

  @@index([workspaceId, email])
  @@index([workspaceId, fullName])
}

model FieldSource {
  id          String    @id @default(cuid())
  workspaceId String
  companyId   String?
  contactId   String?
  fieldName   String
  fieldValue  String
  source      String
  trustScore  Int
  confidence  Int?
  seenAt      DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company     Company?  @relation(fields: [companyId], references: [id])
  contact     Contact?  @relation(fields: [contactId], references: [id])

  @@index([workspaceId, fieldName])
}

model VerificationResult {
  id          String            @id @default(cuid())
  workspaceId String
  contactId   String
  provider    String
  email       String?
  phone       String?
  grade       VerificationGrade
  status      String
  checks      Json
  rawResponse Json
  verifiedAt  DateTime          @default(now())
  expiresAt   DateTime?
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact     Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([workspaceId, grade])
  @@index([workspaceId, expiresAt])
}

model EnrichmentResult {
  id          String    @id @default(cuid())
  workspaceId String
  contactId   String?
  companyId   String?
  provider    String
  confidence  Int?
  fields      Json
  rawResponse Json
  enrichedAt  DateTime  @default(now())
  expiresAt   DateTime?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([workspaceId, provider])
}

model Segment {
  id          String          @id @default(cuid())
  workspaceId String
  name        String
  rules       Json
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  records     RecordSegment[]

  @@unique([workspaceId, name])
}

model RecordSegment {
  id          String    @id @default(cuid())
  workspaceId String
  segmentId   String
  contactId   String?
  companyId   String?
  assignedAt  DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  segment     Segment   @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@index([workspaceId, segmentId])
}

model LeadScore {
  id           String       @id @default(cuid())
  workspaceId  String
  contactId    String?
  companyId    String?
  score        Int
  priority     PriorityTier
  breakdown    Json
  calculatedAt DateTime     @default(now())
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([workspaceId, priority])
}

model Export {
  id             String    @id @default(cuid())
  workspaceId    String
  leadJobId      String?
  name           String
  exportType     String
  filterSnapshot Json
  columns        String[]
  recordCount    Int
  fileUrl        String?
  createdById    String?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime?
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leadJob        LeadJob?  @relation(fields: [leadJobId], references: [id])

  @@index([workspaceId, createdAt])
}

model SuppressionRecord {
  id          String          @id @default(cuid())
  workspaceId String
  type        SuppressionType
  email       String?
  phone       String?
  domain      String?
  reason      String
  source      String
  createdById String?
  createdAt   DateTime        @default(now())
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, email])
  @@index([workspaceId, phone])
  @@index([workspaceId, domain])
}

model Account {
  id             String        @id @default(cuid())
  workspaceId    String
  companyId      String?       @unique
  name           String
  domain         String?
  industry       String?
  location       String?
  ownerUserId    String?
  source         String?
  score          Int?
  priority       PriorityTier?
  complianceNote String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company        Company?      @relation(fields: [companyId], references: [id])
  contacts       CrmContact[]
  opportunities  Opportunity[]
  activities     Activity[]
  tasks          Task[]
  notes          Note[]
  callLogs       CallLog[]
  sdrAssignments SdrAssignment[]
  followUpReminders FollowUpReminder[]
  emailEvents    EmailEvent[]
  smsEvents      SmsEvent[]
  trackedCalls   TrackedCall[]

  @@index([workspaceId, domain])
  @@index([workspaceId, ownerUserId])
}

model CrmContact {
  id          String   @id @default(cuid())
  workspaceId String
  accountId   String
  contactId   String?
  fullName    String
  title       String?
  email       String?
  phone       String?
  status      String
  ownerUserId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact     Contact? @relation(fields: [contactId], references: [id])
  opportunities Opportunity[]
  activities Activity[]
  tasks      Task[]
  notes      Note[]
  callLogs   CallLog[]
  sdrAssignments SdrAssignment[]
  followUpReminders FollowUpReminder[]
  emailEvents EmailEvent[]
  smsEvents SmsEvent[]
  trackedCalls TrackedCall[]

  @@index([workspaceId, accountId])
  @@index([workspaceId, email])
}

model Opportunity {
  id                String           @id @default(cuid())
  workspaceId       String
  accountId         String
  name              String
  stage             OpportunityStage @default(PROSPECTING)
  amountCents       Int              @default(0)
  probability       Int              @default(0)
  expectedCloseDate DateTime?
  ownerUserId       String?
  contactId         String?
  source            String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  workspace         Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account           Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact           CrmContact?      @relation(fields: [contactId], references: [id])
  owner             User?            @relation("OpportunityOwner", fields: [ownerUserId], references: [id])
  activities        Activity[]

  @@index([workspaceId, stage])
  @@index([workspaceId, ownerUserId])
  @@index([workspaceId, contactId])
}

model Activity {
  id          String       @id @default(cuid())
  workspaceId String
  accountId   String?
  contactId   String?
  opportunityId String?
  actorUserId String?
  type        ActivityType
  title       String
  body        String?
  metadata    Json?
  occurredAt  DateTime     @default(now())
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account     Account?     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact     CrmContact?  @relation(fields: [contactId], references: [id])
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id])
  actor       User?        @relation(fields: [actorUserId], references: [id])

  @@index([workspaceId, accountId, occurredAt])
  @@index([workspaceId, contactId, occurredAt])
  @@index([workspaceId, opportunityId, occurredAt])
}

model Task {
  id          String    @id @default(cuid())
  workspaceId String
  accountId   String?
  contactId   String?
  title       String
  status      String    @default("open")
  priority    String    @default("normal")
  dueAt       DateTime?
  ownerUserId String?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account     Account?  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact     CrmContact? @relation(fields: [contactId], references: [id])
  owner       User?     @relation("TaskOwner", fields: [ownerUserId], references: [id])
  createdBy   User?     @relation("TaskCreator", fields: [createdById], references: [id])

  @@index([workspaceId, ownerUserId, dueAt])
  @@index([workspaceId, contactId])
}

model Note {
  id          String   @id @default(cuid())
  workspaceId String
  accountId   String?
  contactId   String?
  body        String
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account     Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact     CrmContact? @relation(fields: [contactId], references: [id])
  createdBy   User?    @relation("NoteCreator", fields: [createdById], references: [id])

  @@index([workspaceId, accountId])
  @@index([workspaceId, contactId])
}

model CallLog {
  id              String      @id @default(cuid())
  workspaceId     String
  accountId       String?
  contactId       String?
  phone           String
  outcome         String
  durationSeconds Int         @default(0)
  notes           String?
  createdById     String?
  createdAt       DateTime    @default(now())
  workspace       Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account         Account?    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact         CrmContact? @relation(fields: [contactId], references: [id])
  createdBy       User?       @relation(fields: [createdById], references: [id])

  @@index([workspaceId, accountId, createdAt])
  @@index([workspaceId, contactId, createdAt])
}

model CustomField {
  id          String             @id @default(cuid())
  workspaceId String
  objectType  String
  name        String
  fieldType   String
  options     String[]
  createdAt   DateTime           @default(now())
  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  values      CustomFieldValue[]

  @@index([workspaceId, objectType])
}

model CustomFieldValue {
  id            String      @id @default(cuid())
  workspaceId   String
  customFieldId String
  objectId      String
  value         String
  updatedAt     DateTime    @updatedAt
  workspace     Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([customFieldId, objectId])
  @@index([workspaceId, objectId])
}

model SdrTeam {
  id              String             @id @default(cuid())
  workspaceId     String
  name            String
  managerUserId   String?
  memberUserIds   String[]
  territories     String[]
  industries      String[]
  capacityWeight  Float              @default(1)
  active          Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  workspace       Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  manager         User?              @relation("SdrTeamManager", fields: [managerUserId], references: [id])
  assignments     SdrAssignment[]
  reassignmentRules ReassignmentRule[]

  @@index([workspaceId, active])
}

model SdrAssignment {
  id                  String             @id @default(cuid())
  workspaceId          String
  accountId            String?
  contactId            String?
  assignedSdrId        String?
  assignedTeamId       String?
  assignedById         String?
  assignmentMethod     String
  assignmentReason     String
  assignedAt           DateTime          @default(now())
  firstTouchDueAt      DateTime?
  followUpDueAt        DateTime?
  status               String
  reassignmentReason   String?
  previousOwnerId      String?
  slaStatus            String
  firstTouchedAt       DateTime?
  lastTouchAt          DateTime?
  touchCount           Int               @default(0)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  workspace            Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account              Account?          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact              CrmContact?       @relation(fields: [contactId], references: [id])
  assignedSdr          User?             @relation("AssignedSdr", fields: [assignedSdrId], references: [id])
  assignedBy           User?             @relation("AssignmentCreator", fields: [assignedById], references: [id])
  assignedTeam         SdrTeam?          @relation(fields: [assignedTeamId], references: [id])
  reminders            FollowUpReminder[]

  @@unique([workspaceId, contactId])
  @@index([workspaceId, assignedSdrId, status])
  @@index([workspaceId, slaStatus])
  @@index([workspaceId, firstTouchDueAt])
